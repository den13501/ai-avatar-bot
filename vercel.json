{
  "version": 2,
  "builds": [
    { "src": "api/tts.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "embed.js", "use": "@vercel/static" },
    { "src": "knowledge.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/tts", "dest": "/api/tts.js" },
    { "src": "/", "dest": "/index.html" },
    { "handle": "filesystem" }
  ]
}
